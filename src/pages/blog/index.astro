---
import BaseLayout from '../../layouts/BaseLayout.astro';
const blogModules = import.meta.glob('../../content/blog/*.md', { eager: true });
const posts = Object.values(blogModules)
  .map((module: any) => ({
    ...module.frontmatter,
    slug: module.file ? module.file.split('/').pop().replace('.md', '') : '',
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---
<BaseLayout title="Blog | Raoul Mahtani">
  <section style="margin-top: 2rem;">
    <h2>Blog</h2>
    <p style="color: #cbd5f5; max-width: 60ch;">
      Notes from the SRE trenches, experiments on toolchains, and whatever I build when a pager sleepifies me. Bookmark the
      section and drop back when you want the latest thoughts.
    </p>
  </section>
  <div class="grid" style="margin-top: 2rem;">
    {posts.map((post) => (
      <article
        style="background: rgba(15, 23, 42, 0.7); padding: 1.5rem; border-radius: 1rem; border: 1px solid rgba(148, 163, 184, 0.15);"
        key={post.slug}
      >
        <p style="color: #94a3b8; margin: 0; font-size: 0.85rem;">{new Date(post.date).toLocaleDateString()}</p>
        <h3 style="margin-top: 0.5rem;">{post.title}</h3>
        <p style="color: #cbd5f5; line-height: 1.6;">{post.summary}</p>
        <a href={`/blog/${post.slug}`} style="color: #facc15; font-weight: 600;">Read →</a>
      </article>
    ))}
  </div>
</BaseLayout>
