---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<BaseLayout title="Raoul Mahtani | Blog">
  <section style="margin-top: 3rem;">
    <h1 style="margin-bottom: 0.5rem;">Journal</h1>
    <p style="color: #cbd5f5; margin-bottom: 1.5rem;">
      Longer posts, deployment notes, and lessons from life as an SRE.
    </p>
    <div style="display: grid; gap: 1.25rem;">
      {posts.map((post) => (
        <article
          style="background: rgba(15, 23, 42, 0.7); padding: 1.5rem; border-radius: 1rem; border: 1px solid rgba(148, 163, 184, 0.15);"
          key={post.slug}
        >
          <p style="color: #94a3b8; margin: 0 0 0.3rem; font-size: 0.9rem;">
            {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </p>
          <h2 style="margin: 0 0 0.5rem;">{post.data.title}</h2>
          <p style="color: #cbd5f5; margin: 0 0 0.75rem; line-height: 1.6;">{post.data.summary}</p>
          <a href={`/blog/${post.slug}`} style="color: #facc15; text-decoration: none; font-weight: 600;">Read →</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
