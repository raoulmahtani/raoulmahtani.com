---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: {
      slug: post.slug,
    },
  }));
}

const { slug } = Astro.params;
const post = (await getCollection('blog')).find((item) => item.slug === slug) as CollectionEntry<'blog'> | undefined;

if (!post) {
  throw new Error(`Blog post not found: ${slug}`);
}
---
<BaseLayout title={`Raoul Mahtani | ${post.data.title}`}>
  <article style="margin-top: 3rem;">
    <p style="color: #94a3b8; font-size: 0.9rem; margin-bottom: 0.25rem;">
      {new Date(post.data.date).toLocaleDateString('en-US', {
        month: 'short',
        day: 'numeric',
        year: 'numeric',
      })}
    </p>
    <h1 style="margin-bottom: 0.5rem;">{post.data.title}</h1>
    <div style="color: #cbd5f5; line-height: 1.8;">
      {post.body ? post.body : post.data.summary}
    </div>
  </article>
</BaseLayout>
