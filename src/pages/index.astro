---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const resumeUrl = 'https://github.com/raoulmahtani/resume/raw/refs/heads/main/Raoul%20Mahtani%20Resume.pdf';
const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const experience = [
  {
    company: 'Flatiron Health',
    title: 'Senior Site Reliability Engineer',
    timeline: 'Jan 2024 – Present · Remote (New York, NY)',
    description:
      'Leading reliability initiatives for Flatiron’s clinical research platform, pairing observability projects with incident prevention playbooks while mentoring the next generation of SREs.',
  },
  {
    company: 'Flatiron Health',
    title: 'Site Reliability Engineer',
    timeline: 'May 2022 – Jan 2024 · New York, NY',
    description:
      'Owned production readiness for health data pipelines; shipped automation around deployment guards, runbooks, and operational telemetry.',
  },
  {
    company: 'BlackRock',
    title: 'Site Reliability Engineer',
    timeline: 'Jun 2017 – May 2022 · Greater Philadelphia',
    description:
      'Architected automation across Node.js/Cassandra/Angular services, authored HashiCorp-backed deployment playbooks, and built Kafka consumers to surface real-time platform metrics.',
  },
  {
    company: 'BlackRock',
    title: 'GTI Rotational Analyst',
    timeline: 'Jul 2014 – Feb 2017 · Wilmington, DE',
    description:
      'Administered enterprise Windows infrastructure, led storage zoning projects, and helped run disaster recovery rehearsals for the East Coast data center.',
  },
];

const hobbies = [
  'Tracking the stock market’s narrative arcs and using events to shape experimental automation ideas.',
  'Following real estate cycles closely—especially small coastal markets like my Rehoboth Beach Airbnb.',
  'Collecting vintage timepieces and learning the craft of horology whenever a call never comes.',
  'Cooking spicy food that matches the intensity of a production incident response.',
];
---
<BaseLayout title="Raoul Mahtani | SRE & storyteller">
  <section style="margin-top: 2rem;">
    <p style="color: #f9c74f; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.8rem; margin-bottom: 0.5rem;">SRE · writer · curious human</p>
    <h2 style="margin-top: 0; font-size: clamp(2rem, 4vw, 3rem);">Keeping systems stable and stories readable.</h2>
    <p style="max-width: 56ch; color: #cbd5f5; font-size: 1.1rem; line-height: 1.8;">
      I’m an SRE at Flatiron Health. I’ve baked reliability into clinical research platforms by shipping observability, automation, and
      on-call tooling that lets investigators focus on delivering care rather than firefighting. Raised in Jamaica, I blend serious business
      culture with an engineer’s curiosity—always asking how we can automate the next manual guardrail or document the playbook for the
      next incident.
    </p>
  </section>

  <section id="about" style="margin-top: 3rem;">
    <h3 style="margin-bottom: 1rem;">About me</h3>
    <div class="grid grid-two" style="align-items: stretch;">
      <article style="background: rgba(15, 23, 42, 0.8); padding: 1.75rem; border-radius: 1rem; box-shadow: 0 20px 45px rgba(2, 6, 23, 0.45);">
        <p style="color: #cbd5f5; line-height: 1.7; margin-bottom: 1rem;">
          I build reliable platforms and help teams feel confident that their software behaves when it matters. My toolkit covers distributed
          systems, Python tooling, and capturing the “why” behind every fix so we can explain it to other humans.
        </p>
        <p style="color: #cbd5f5; line-height: 1.7; margin-bottom: 1rem;">Outside the console, I’m all about long rides, travel, and exploring new approaches to leadership in operations.</p>
        <p style="margin: 0; color: #cbd5f5; line-height: 1.7;">Hobbies? Keep scrolling.</p>
      </article>
      <article style="background: rgba(15, 23, 42, 0.6); padding: 1.75rem; border-radius: 1rem;">
        <h4 style="margin-top: 0;">Experience highlights</h4>
        <ul style="padding-left: 1rem; color: #cbd5f5; line-height: 1.7;">
          <li>Flatiron Health SRE since 2022, focused on automation, observability, and partnered incidents.</li>
          <li>BlackRock SRE/analyst shaping automation for Node.js/Cassandra platforms and driving infrastructure playbooks (Packer/Terraform).</li>
          <li>GTI rotational work on enterprise Windows infrastructure, standby DR rehearsals, and storage modernization.</li>
        </ul>
      </article>
    </div>
  </section>

  <section id="experience" style="margin-top: 3rem;">
    <h3>Professional timeline</h3>
    <div class="grid" style="margin-top: 1rem;">
      {experience.map((entry) => (
        <article
          style="background: rgba(15, 23, 42, 0.7); padding: 1.5rem; border-radius: 1rem; border: 1px solid rgba(148, 163, 184, 0.15);"
          key={entry.title + entry.company}
        >
          <p style="color: #94a3b8; margin: 0 0 0.25rem; font-size: 0.9rem;">{entry.timeline}</p>
          <h4 style="margin: 0 0 0.5rem;">{entry.title}</h4>
          <p style="color: #cbd5f5; margin: 0 0 0.5rem; line-height: 1.6; font-weight: 600;">{entry.company}</p>
          <p style="color: #cbd5f5; margin: 0; line-height: 1.6; font-size: 0.95rem;">{entry.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="hobbies" style="margin-top: 3rem;">
    <h3>Hobbies & interests</h3>
    <p style="color: #cbd5f5; max-width: 60ch;">
      I keep a few side projects alive to sharpen creativity—stock market narratives to inform automation ideas, a Rehoboth Beach Airbnb,
      timepiece collecting, and spicy food experiments that rival a production incident for intensity.
    </p>
    <ul style="padding-left: 1rem; color: #cbd5f5; line-height: 1.7;">
      {hobbies.map((item) => (
        <li key={item}>{item}</li>
      ))}
    </ul>
  </section>

  <section id="resume" style="margin-top: 3rem; display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: stretch;">
    <article style="flex: 1; min-width: 250px; background: rgba(15, 23, 42, 0.7); padding: 1.5rem; border-radius: 1rem;">
      <h3>Resume</h3>
      <p style="color: #cbd5f5; line-height: 1.7;">
        Download the latest PDF (mirror from my resume repository) or open it inline in a new tab.
      </p>
      <a href={resumeUrl} style="color: #facc15; font-weight: 600; text-decoration: none;">Open resume</a>
      <p style="margin-top: 0.75rem; color: #94a3b8; font-size: 0.9rem;">Let me know if you want other formats (Markdown, Notion, etc.).</p>
    </article>
    <article style="flex: 1 1 320px; background: rgba(15, 23, 42, 0.6); padding: 1.5rem; border-radius: 1rem; border: 1px solid rgba(250, 204, 21, 0.25);">
      <h3>Analytics & monitoring</h3>
      <p style="color: #cbd5f5; line-height: 1.7;">
        Right now I’m thinking GoatCounter or Cloudflare Web Analytics for a lightweight, privacy-friendly view of traffic without
        loading heavy scripts. Once we deploy through GitHub Pages or Cloudflare Pages, I can drop in the snippet of your choice.
      </p>
      <p style="margin: 0; color: #cbd5f8; font-size: 0.9rem;">
        Want me to wire one in today? Just say which provider you prefer.
      </p>
    </article>
  </section>

  <section id="blog" style="margin-top: 3rem;">
    <div style="display: flex; justify-content: space-between; align-items: baseline;">
      <h2 style="margin: 0;">Blog</h2>
      <a href="/blog" style="color: #facc15; text-decoration: none; font-weight: 600;">See all posts →</a>
    </div>
    <div class="grid" style="margin-top: 1.5rem;">
      {posts.map((post) => (
        <article
          style="background: rgba(15, 23, 42, 0.7); padding: 1.5rem; border-radius: 1rem; border: 1px solid rgba(148, 163, 184, 0.15);"
          key={post.slug}
        >
          <p style="color: #94a3b8; margin: 0; font-size: 0.9rem;">{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</p>
          <h3 style="margin: 0.5rem 0;">{post.data.title}</h3>
          <p style="color: #cbd5f5; line-height: 1.6;">{post.data.summary}</p>
          <a
            href={`/blog/${post.slug}`}
            style="color: #facc15; font-weight: 600; text-decoration: none;"
          >
            Read →
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
